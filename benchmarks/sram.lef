MACRO SRAM1024x32
  SIZE 150 BY 150
  PIN clk
    DIRECTION INPUT
    RECT 0 50 2 52
  END clk
  PIN en
    DIRECTION INPUT
    RECT 0 100 2 102
  END en
  PIN addr
    DIRECTION INPUT
    RECT 50 148 52 150
  END addr
  PIN din
    DIRECTION INPUT
    RECT 100 148 102 150
  END din
  PIN dout
    DIRECTION OUTPUT
    RECT 148 75 150 77
  END dout
END SRAM1024x32
