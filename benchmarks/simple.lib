library(simple) {
    /* ================================================================
     * Byteflow Standard Cell Library - 45nm Generic Process
     * PHASE 5: Full NLDM Timing Characterization
     * 
     * Index 1: Input transition time (slew) in ps
     * Index 2: Output load capacitance in fF
     * Values : Delay / transition time in ps
     * ================================================================ */

    cell(BUF) {
        area : 6;
        pin(A) {
            direction : input;
            capacitance : 0.004;
        }
        pin(Y) {
            direction : output;
            function : "A";

            timing() {
                related_pin : "A";

                cell_rise(nldm_3x3) {
                    index_1("10.0, 50.0, 200.0");
                    index_2("1.0, 5.0, 20.0");
                    values("12.0, 18.0, 35.0", \
                           "15.0, 22.0, 42.0", \
                           "25.0, 35.0, 65.0");
                }
                cell_fall(nldm_3x3) {
                    index_1("10.0, 50.0, 200.0");
                    index_2("1.0, 5.0, 20.0");
                    values("10.0, 16.0, 32.0", \
                           "13.0, 20.0, 38.0", \
                           "22.0, 32.0, 60.0");
                }
                rise_transition(nldm_3x3) {
                    index_1("10.0, 50.0, 200.0");
                    index_2("1.0, 5.0, 20.0");
                    values("15.0, 25.0, 55.0", \
                           "20.0, 35.0, 75.0", \
                           "40.0, 60.0, 120.0");
                }
                fall_transition(nldm_3x3) {
                    index_1("10.0, 50.0, 200.0");
                    index_2("1.0, 5.0, 20.0");
                    values("13.0, 22.0, 50.0", \
                           "18.0, 30.0, 68.0", \
                           "35.0, 55.0, 110.0");
                }
            }
        }
    }

