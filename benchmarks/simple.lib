    cell(DFF) {
        area : 18;
        ff(IQ, IQN) { clocked_on : C; next_state : D; }
        pin(C) {
            direction : input;
            clock : true;
            capacitance : 0.006;
        }
        pin(D) {
            direction : input;
            capacitance : 0.004;

            timing() {
                related_pin : "C";
                setup_constraint : 50.0;
                hold_constraint : 20.0;
            }
        }
        pin(Q) {
            direction : output;
            function : "IQ";

            timing() {
                related_pin : "C";

                cell_rise(nldm_3x3) {
                    index_1("10.0, 50.0, 200.0");
                    index_2("1.0, 5.0, 20.0");
                    values("45.0, 65.0, 120.0", \
