    END
  END Y
END NOR2

MACRO NOT
  CLASS CORE ;
  SIZE 1 BY 1 ;
  PIN A
    DIRECTION INPUT ;
    PORT
      LAYER Metal1 ;
      RECT 0.05 0.45 0.15 0.55 ;
    END
  END A
  PIN Y
    DIRECTION OUTPUT ;
    PORT
      LAYER Metal1 ;
      RECT 0.85 0.45 0.95 0.55 ;
    END
  END Y
END NOT

